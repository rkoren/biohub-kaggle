export MLFLOW_TRACKING_URI=sqlite:///mlruns.db
export MLFLOW_EXPERIMENT=biohub-cell-tracking
export MLFLOW_MODEL_NAME=biohub-cell-tracking-model
export MLFLOW_PROMOTE_METRIC=track_score
export MLFLOW_PROMOTE_LOWER_IS_BETTER=false
export AWS_PROFILE=default

# Kaggle credentials are read from ~/.kaggle/kaggle.json by default.
# Uncomment to override via environment instead:
# export KAGGLE_USERNAME=your-username
# export KAGGLE_KEY=your-api-key
